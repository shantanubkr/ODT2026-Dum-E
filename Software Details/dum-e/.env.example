# Copy to .env and fill in ( .env is gitignored ).
# Do not commit real API keys or device paths to a public repo.

# --- USB control (typical: firmware on ESP, app on Mac, no Bluetooth) ---
# 0 = send commands over USB serial. 1 = BLE (needs USE_BLE_NUS on ESP + bleak).
DUM_E_BLE=0
# macOS: list with: ls /dev/cu.usb*   Close Thonny/mpremote before starting the app.
DUM_E_SERIAL_PORT=/dev/cu.usbserial-0001
# DUM_E_SERIAL_BAUD=115200

# 0 = real arm. 1 = sim only (no serial).
DUM_E_SIM_MOTION=0

# Optional: Google Gemini (desktop AI)
GEMINI_API_KEY=

# Optional — only if DUM_E_BLE=1
# DUM_E_BLE_NAME=DUM-E
# DUM_E_BLE_ADDRESS=...

# mpremote deploy uses DUM_E_MPREMOTE_PORT if set (see deploy/common.sh), else auto-detect.

# 1 = skip subprocess ROS; use serial/BLE or sim only.
DUM_E_SKIP_ROS2=1

# Optional: MJPEG for vision (desktop)
# DUM_E_VISION_URL=http://10.0.0.1:81/stream
